---
import { Button, Collapse, Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'

const headings = [
  { depth: 2, slug: 'tools', text: 'Tools' },
  { depth: 2, slug: 'social-networks', text: 'Social Networks' },
  { depth: 2, slug: 'about-blog', text: 'About Blog' }
]
---

<PageLayout title='About' {headings} comment>
  <h2 id='general-talk' class='invisible m-0 h-0'>General Talk</h2>
  <p class='text-muted-foreground'>Robotics Engineer / AI Researcher</p>
  <p>你好，我是unreal，是北京大学工学院机器人工程专业的本科生。</p>
  <p>
    我致力于完善具身智能、智能机器人技术并在工业应用领域发挥力量。即将入学北京大学先进制造与机器人学院攻读机械工程硕士。
  </p>
  <p>我的研究兴趣包括 Embodied Intelligence、Vision-Language-Action (VLA) Models、Multimodal Fusion 和 Multi-Robot Collaboration。</p>
  <p>我喜欢阅读、音乐、电影和宝可梦。</p>

  {/* tools */}
  <h2 id='tools'>Tools</h2>
  <p>以下是我正在使用的一些工具：</p>
  <ToolSection
    class='mb-5'
    title='Productivity'
    tools={[
      {
        name: 'Chrome',
        description: 'Browser',
        href: 'https://www.google.com/chrome/',
        icon: import('@/assets/tools/chrome.svg?raw')
      },
      {
        name: 'Firefox',
        description: 'Browser',
        href: 'https://www.mozilla.org/firefox/',
        icon: import('@/assets/tools/firefox.svg?raw')
      },
      {
        name: 'Obsidian',
        description: 'Note Taking',
        href: 'https://obsidian.md/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'Typora',
        description: 'Markdown Editor',
        href: 'https://typora.io/',
        icon: import('@/assets/tools/typora.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Development'
    tools={[
      {
        name: 'Claude Code',
        description: 'AI Code Assistant',
        href: 'https://claude.ai/',
        icon: import('@/assets/tools/chatgpt.svg?raw')
      },
      {
        name: 'VS Code',
        description: 'IDE',
        href: 'https://code.visualstudio.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Environment'
    tools={[
      {
        name: 'Ubuntu 24.04 LTS',
        description: 'Linux Distribution',
        href: 'https://ubuntu.com/',
        icon: import('@/assets/tools/ubuntu.svg?raw')
      },
      {
        name: 'Windows 11',
        description: 'Desktop',
        href: 'https://www.microsoft.com/windows/',
        icon: import('@/assets/tools/windows11.svg?raw')
      }
    ]}
  />

  {/* social-networks */}
  <h2 id='social-networks'>Social Networks</h2>
  <p>你可以在以下平台找到我：</p>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/satopikac',
        text: 'followers',
        api: 'github/satopikac'
      },
      // {
      //   platform: 'Zhihu',
      //   icon: 'zhihu',
      //   color: '#0084ff',
      //   link: 'https://www.zhihu.com/people/wmrbxv',
      //   text: 'followers',
      //   api: 'zhihu/wmrbxv'
      // },
      // {
      //   platform: 'Bilibili',
      //   icon: 'bilibili',
      //   color: '#fe7398',
      //   link: 'https://space.bilibili.com/49978858',
      //   text: 'followers',
      //   api: 'bilibili/49978858'
      // }
    ]}
  />

  {/* about-blog */}
  <h2 id='about-blog'>About Blog</h2>
  <p>本站基于以下项目/服务提供商的资源和技术支持：</p>
  <ul>
    <li>
      框架 & 主题: <a href='https://astro.build/' target='_blank'>Astro</a> + <a
        href='https://github.com/cworld1/astro-theme-pure'
        target='_blank'>Astro Theme Pure</a
      >
    </li>
    <li>
      托管: <a href='https://pages.github.com/' target='_blank'>GitHub Pages</a>
    </li>
    <li>
      CI/CD: <a href='https://github.com/features/actions' target='_blank'>GitHub Actions</a>
    </li>
    <li>评论系统：<a href='https://waline.js.org' target='_blank'>Waline</a></li>
  </ul>
</PageLayout>
