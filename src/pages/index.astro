---
import { Image } from 'astro:assets'

import { Quote } from 'astro-pure/advanced'
import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import ProjectCard from '@/components/home/ProjectCard.astro'
import Section from '@/components/home/Section.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import config from '@/site-config'

const programming = ['C++', 'C', 'Python', 'MATLAB']
const robotics = ['ROS', 'SLAM', 'SolidWorks', 'AutoDesk Fusion']
const webDev = ['HTML', 'CSS', 'JavaScript', 'Astro']
const tools = ['Git', 'Linux', 'VS Code', 'LaTeX']

const MAX_POSTS = 10
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS)

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp}'
)
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`
  )
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={images[imagePath]()}
        alt={config.logo.alt || 'Profile'}
        class='h-28 w-auto rounded-full border p-1'
        loading='eager'
        fetchpriority='high'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-bold'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title='China / Beijing'>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          <Label
            title='GitHub'
            as='a'
            href='https://github.com/satopikac'
            target='_blank'
          >
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='About'>
        <p class='text-muted-foreground mt-1'>Robotics Engineer / AI Researcher</p>
        <div class='flex flex-col gap-2 leading-6 text-muted-foreground'>
          <p>你好，我叫梅庆宇 (Mei Qingyu)，是北京大学工学院机器人工程专业的本科生。</p>
          <p>
            我致力于完善具身智能、智能机器人技术并在工业应用领域发挥力量。研究兴趣包括 Embodied Intelligence、Vision-Language-Action (VLA) Models、Multimodal Fusion 和 Multi-Robot Collaboration。
          </p>
          <p>即将入学北京大学先进制造与机器人学院攻读机械工程硕士。</p>
        </div>
        <Button title='More about me' class='w-fit self-end' href='/about' variant='ahead' />
      </Section>
      {
        allPostsByDate.length > 0 && (
          <Section title='Posts'>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {allPostsByDate.map((p) => (
                <li class='flex flex-col gap-x-2 sm:flex-row'>
                  <PostPreview post={p} />
                </li>
              ))}
            </ul>
            <Button title='More posts' class='w-fit self-end' href='/blog' variant='ahead' />
          </Section>
        )
      }

      <Section title='Education'>
        <Card
          as='a'
          heading='北京大学 工学院'
          subheading='机器人工程 · GPA: 3.742/4.0 (Rank: 3rd)'
          date='2022 - Present'
          href='https://www.coe.pku.edu.cn/'
        >
          <img
            class='absolute end-0 z-0 m-0 -my-3 h-full w-1/2 object-cover opacity-40'
            src='/images/PKU.svg'
          />
        </Card>
        <Card
          as='a'
          heading='北京大学 先进制造与机器人学院'
          subheading='机械工程硕士 (2026年入学)'
          date='2026 - '
          href='https://amr.pku.edu.cn/'
        >
          <img
            class='absolute end-0 z-0 m-0 -my-3 h-full w-1/2 object-cover opacity-40'
            src='/images/PKU.svg'
          />
        </Card>
      </Section>

      <Section title='Research'>
        <Card
          as='a'
          heading='具身智能语义感知与导航Agent'
          subheading='语义感知与导航，多机器人协作'
          date='2025 - Present'
          href='https://github.com/satopikac'
        />
        <Card
          as='a'
          heading='语义导航与点云语义分割'
          subheading='语义导航技术研究与点云语义分割开发'
          date='2024 - Present'
          href='https://github.com/satopikac'
        />
        <Card
          as='a'
          heading='轮式机器人SLAM与协作机械臂抓取'
          subheading='室内2D地图构建与机械臂路径规划'
          date='2024 - 2025'
          href='https://github.com/satopikac'
        />
      </Section>

      <Section title='Skills'>
        <SkillLayout title='编程语言' skills={programming} />
        <SkillLayout title='机器人与工程' skills={robotics} />
        <SkillLayout title='Web开发' skills={webDev} />
        <SkillLayout title='工具' skills={tools} />
      </Section>
    </div>
    <Quote class='mt-12' />
  </main>
</PageLayout>
